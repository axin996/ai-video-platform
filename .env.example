# Environment variables for AI Video Platform
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_video_platform
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_video_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-to-a-random-secret-key

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-video-platform
MINIO_SECURE=False

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CosyVoice TTS Service
COSYVOICE_BASE_URL=http://localhost:9880

# HeyGem Digital Human Service
HEYGEM_BASE_URL=http://localhost:8081
HEYGEM_MODELS_DIR=/mnt/models/heygem

# Whisper
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Playwright / Chrome
CHROME_DEBUG_PORT=9222
CHROME_PATH=/usr/bin/google-chrome

# Platform OAuth Credentials
# Bilibili
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Flower (Celery monitoring)
FLOWER_PORT=5555
